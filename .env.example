# Supabase（ダッシュボード → Project Settings → API）
# このファイルをコピーして `.env.local` を作成し、値を埋めてください。
# https://supabase.com/dashboard

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Storage アップロード（Server Action 用・ダッシュボード → Project Settings → API → service_role）
# 必須: Storage で public バケット「avatars」「headers」を作成（名前は完全一致）
# ダッシュボード → Storage → New bucket → Name: avatars → Public bucket ON → 同様に headers
SUPABASE_SERVICE_ROLE_KEY=
# directUrl を付けない場合は、Transaction pooler(6543) ではなく Session pooler(5432) を推奨。
# パスワードに @ , などがある場合は URL エンコード（例: , → %2C）してください。
DATABASE_URL=

# Clerk（ダッシュボードの API Keys と合わせて `.env.local` に設定）
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Clerk → Webhooks → Endpoint 例: https://あなたのドメイン/api/webhooks/clerk
# 推奨イベント: user.created, user.updated, user.deleted（メール検証後の保存は user.updated 必須）
# 認証のたびに DB 行を確実に揃えたい場合は session.created も追加（検証済みユーザーのみ upsert）
# 値に + などがあるときは必ずダブルクォートで囲む（未クォートだと環境によっては壊れる）
CLERK_WEBHOOK_SIGNING_SECRET=
# カスタムサインイン/サインアップページ（このリポジトリでは /sign-in と /sign-up）
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
